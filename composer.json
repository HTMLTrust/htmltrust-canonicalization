{
    "name": "htmltrust/canonicalization",
    "description": "HTMLTrust canonical text normalization for PHP",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "HTMLTrust\\Canonicalization\\": "php/src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "HTMLTrust\\Canonicalization\\Tests\\": "php/tests/"
        }
    },
    "require": {
        "php": ">=7.2",
        "ext-intl": "*",
        "ext-mbstring": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^8.0 || ^9.0 || ^10.0"
    }
}
