{
  "name": "htmltrust/canonicalization",
  "description": "HTMLTrust canonical text normalization for PHP",
  "type": "library",
  "license": "LicenseRef-PolyForm-Noncommercial-1.0.0",
  "autoload": {
    "psr-4": {
      "HTMLTrust\\Canonicalization\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "HTMLTrust\\Canonicalization\\Tests\\": "tests/"
    }
  },
  "require": {
    "php": ">=7.2",
    "ext-intl": "*",
    "ext-mbstring": "*",
    "ext-json": "*",
    "ext-openssl": "*",
    "ext-sodium": "*"
  },
  "suggest": {
    "ext-curl": "Used by the default HttpFetcher for keyid resolution; falls back to file_get_contents when missing."
  },
  "require-dev": {
    "phpunit/phpunit": "^8.0 || ^9.0 || ^10.0"
  },
  "scripts": {
    "test": "phpunit --colors=always tests/"
  }
}
